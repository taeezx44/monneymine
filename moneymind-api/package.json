{
  "name": "moneymind-api",
  "version": "1.0.0",
  "description": "MoneyMind AI Expense Tracker — REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev":          "tsx watch src/server.ts",
    "build":        "tsc --project tsconfig.json",
    "start":        "node dist/server.js",
    "lint":         "eslint src --ext .ts",
    "lint:fix":     "eslint src --ext .ts --fix",
    "test":         "jest --passWithNoTests",
    "test:watch":   "jest --watch",
    "db:migrate":   "node -r tsx/cjs src/db/migrate.ts",
    "db:seed":      "node -r tsx/cjs src/db/seed.ts"
  },
  "dependencies": {
    "express":             "^4.19.2",
    "cors":                "^2.8.5",
    "helmet":              "^7.1.0",
    "compression":         "^1.7.4",
    "morgan":              "^1.10.0",
    "express-rate-limit":  "^7.3.1",
    "express-validator":   "^7.1.0",

    "pg":                  "^8.12.0",
    "redis":               "^4.6.14",

    "@supabase/supabase-js":"^2.43.0",
    "jsonwebtoken":        "^9.0.2",
    "bcryptjs":            "^2.4.3",

    "zod":                 "^3.23.8",
    "date-fns":            "^3.6.0",
    "multer":              "^1.4.5-lts.1",
    "sharp":               "^0.33.4",

    "winston":             "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "dotenv":              "^16.4.5",
    "uuid":                "^10.0.0"
  },
  "devDependencies": {
    "@types/express":      "^4.17.21",
    "@types/cors":         "^2.8.17",
    "@types/compression":  "^1.7.5",
    "@types/morgan":       "^1.9.9",
    "@types/pg":           "^8.11.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs":     "^2.4.6",
    "@types/multer":       "^1.4.11",
    "@types/uuid":         "^10.0.0",
    "@types/node":         "^20.14.0",

    "typescript":          "^5.4.5",
    "tsx":                 "^4.15.7",
    "eslint":              "^9.5.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser":        "^7.13.1",
    "jest":                "^29.7.0",
    "@types/jest":         "^29.5.12",
    "ts-jest":             "^29.1.5",
    "supertest":           "^7.0.0",
    "@types/supertest":    "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
